# 服务配置
WEB_HOST=0.0.0.0
WEB_PORT=5500
WEB_DEBUG=false

# 登录配置
WEB_USERNAME=admin
# 留空时启动后自动生成随机密码
# WEB_PASSWORD=
# Set true only for local development to skip login checks.
WEB_AUTH_DISABLED=false

# JWT 认证配置
# 留空时自动生成随机密钥
# WEB_JWT_SECRET_KEY=
# access token 有效期（分钟），默认 1440（24 小时）
WEB_JWT_ACCESS_TOKEN_EXPIRES_MINUTES=1440
# refresh token 有效期（天），默认 30
WEB_JWT_REFRESH_TOKEN_EXPIRES_DAYS=30
# HTTPS 部署时设为 true
WEB_JWT_COOKIE_SECURE=false
# 跨子域场景可配置，留空则不设置
# WEB_JWT_COOKIE_DOMAIN=

# 首页展示与定时任务配置
# 定时任务调度器总开关：设为 false 不注册、不启动和不执行任何后台定时任务，且不会执行启动时的首页数据补采。
# 可用值：true/false、1/0、yes/no、on/off；修改后需要重启服务。
SCHEDULER_ENABLED=true
UPDATE_INTERVAL=300
TIME_INTERVALS=5m,15m,30m,1h,4h,12h,24h,48h,72h,168h

# 多交易所首页累计
# 首页参与累计的交易所列表，使用英文逗号分隔
ENABLED_EXCHANGES=binance,okx,bybit,gate
# 首页价格参考交易所，价格不累计，仅使用该交易所 K 线价格
PRIMARY_PRICE_EXCHANGE=binance
# 首页需要累计的序列类型，默认只包含首页三类核心数据
HOMEPAGE_SERIES_TYPES=klines,open_interest_hist,taker_buy_sell_vol
# 首页多交易所补采的基础周期
HOMEPAGE_SERIES_REPAIR_ENABLED=true
HOMEPAGE_SERIES_REPAIR_PERIOD=5m
# 首页多交易所补采单次请求条数上限
HOMEPAGE_SERIES_REPAIR_PAGE_LIMIT=500
HOMEPAGE_WINDOW_HEALTH_THRESHOLD=95

# 交易所 API
BINANCE_BASE_URL=https://fapi.binance.com
OKX_BASE_URL=https://www.okx.com
OKX_RUBIK_MIN_INTERVAL_MS=500
OKX_429_RETRY_FALLBACK_SECONDS=5
BYBIT_BASE_URL=https://api.bybit.com
BYBIT_CATEGORY=linear
GATE_BASE_URL=https://fx-api.gateio.ws
GATE_SETTLE=usdt
GATE_MIN_INTERVAL_MS=60
GATE_403_RETRY_FALLBACK_SECONDS=8

# 数据库
# 默认值面向 Docker Compose 内置 MySQL；连接外部 MySQL 时改为外部主机、用户和密码。
# DB_TYPE 支持: mysql、starrocks
DB_TYPE=mysql
DB_HOST=mysql
DB_PORT=3306
DB_USER=coinx
DB_PASSWORD=coinx_password
DB_NAME=coinx
DB_CHARSET=utf8mb4

# Docker Compose 可选 MySQL 容器
# 默认 docker compose up -d 不会启动 MySQL；需要内置 MySQL 时使用：
# docker compose --profile mysql up -d
# MySQL 容器会引用上方 DB_NAME、DB_USER、DB_PASSWORD 初始化应用数据库。
MYSQL_ROOT_PASSWORD=coinx_root_password

# 代理
USE_PROXY=false
PROXY_HOST=127.0.0.1
PROXY_PORT=7897
USE_PROXY_POOL=false
PROXY_POOL_URLS=
PROXY_POOL_STRATEGY=round_robin
PROXY_POOL_FAIL_COOLDOWN_SECONDS=30

# StarRocks 配置（DB_TYPE=starrocks 时使用）
# SR_HOST=
# SR_PORT=9030
# SR_USER=
# SR_PASSWORD=
# SR_DB=

# 币种配置刷新
FETCH_COINS_ENABLED=true
FETCH_COINS_INTERVAL=600
FETCH_COINS_TOP_VOLUME_COUNT=100

# 首页追踪币种补采间隔，单位为秒
REPAIR_TRACKED_INTERVAL=300
REPAIR_ROLLING_POINTS=5
REPAIR_ROLLING_MAX_WORKERS=6
REPAIR_ROLLING_WRITE_BATCH_SIZE=500
REPAIR_HISTORY_ENABLED=true
REPAIR_HISTORY_INTERVAL=3600
REPAIR_HISTORY_MAX_WORKERS=2
REPAIR_HISTORY_WRITE_BATCH_SIZE=2000
REPAIR_HISTORY_SYMBOL_BATCH_SIZE=0
REPAIR_HISTORY_COVERAGE_HOURS=168

# Binance 专属序列管理页配置
# 这些配置只影响 Binance 专属历史序列接口和管理页，不影响首页多交易所累计逻辑。
BINANCE_SERIES_REPAIR_ENABLED=false

# 资金费率定时采集开关
FUNDING_RATE_COLLECT_ENABLED=true
# 资金费率异常阈值（绝对值，如 0.001 表示 0.1%）
FUNDING_RATE_ABNORMAL_THRESHOLD=0.001

# pip 安装镜像源，需要时取消注释
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
