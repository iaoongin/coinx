# 服务器
# Web 服务监听地址
WEB_HOST=0.0.0.0
# Web 服务监听端口
WEB_PORT=5500
# 是否开启调试模式
WEB_DEBUG=false

# 更新间隔
# 主循环更新间隔，单位为秒
UPDATE_INTERVAL=300
# 需要计算和输出的时间周期列表，使用英文逗号分隔
TIME_INTERVALS=5m,15m,30m,1h,4h,12h,24h,48h,72h,168h

# binance series
# 单次抓取的序列数据条数上限
BINANCE_SERIES_LIMIT=30
# 需要抓取的 Binance 序列类型，使用英文逗号分隔
BINANCE_SERIES_TYPES=top_long_short_position_ratio,top_long_short_account_ratio,open_interest_hist,klines,global_long_short_account_ratio

# binance series repair
# 是否启用 Binance 序列补采任务
BINANCE_SERIES_REPAIR_ENABLED=false
# 补采任务执行间隔，单位为秒
BINANCE_SERIES_REPAIR_INTERVAL=900
# 补采任务的基础周期
BINANCE_SERIES_REPAIR_PERIOD=5m
# 启动时向前补采的天数
BINANCE_SERIES_REPAIR_BOOTSTRAP_DAYS=7
# 补采任务覆盖的历史小时数
BINANCE_SERIES_REPAIR_COVERAGE_HOURS=168
# K 线接口单次请求的分页上限
BINANCE_SERIES_REPAIR_KLINES_PAGE_LIMIT=1000
# 合约持仓等接口单次请求的分页上限
BINANCE_SERIES_REPAIR_FUTURES_PAGE_LIMIT=500
# 补采请求之间的休眠时间，单位为毫秒
BINANCE_SERIES_REPAIR_SLEEP_MS=500

# 数据库
# 数据库主机地址
DB_HOST=localhost
# 数据库端口
DB_PORT=3306
# 数据库用户名
DB_USER=root
# 数据库密码
DB_PASSWORD=
# 数据库名称
DB_NAME=coinx
# 数据库字符集
DB_CHARSET=utf8mb4

# 代理
# 是否启用代理访问外部接口
USE_PROXY=false
# 代理主机地址
PROXY_HOST=127.0.0.1
# 代理端口
PROXY_PORT=7897

# binance
# Binance API 基础地址
BINANCE_BASE_URL=https://api.binance.com

# pip 加速源（取消注释启用）
# pip 安装依赖时使用的镜像源地址
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
